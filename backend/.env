# Origens CORS permitidas (separadas por vírgula). Se omitida, usa o padrão de desenvolvimento
# (localhost/127.0.0.1 nas portas 5173 e 4173).
# CORS_ORIGINS=https://app.exemplo.com,http://localhost:5173

# Servir o build do frontend pela API (caminho absoluto para frontend/dist)
# PDF_TOOLS_STATIC=

# Sobrescreve o diretório de uploads temporários. Se omitido: backend/data/uploads ao rodar a partir
# do repositório; se instalado só como wheel, <temp>/pdf_tools_uploads.
# PDF_TOOLS_UPLOAD_DIR=

# --- Autenticação (opcional) ---
AUTH_ENABLED=true
# Provedor ativo quando AUTH_ENABLED=true. Hoje: apenas ldap.
AUTH_PROVIDER=ldap
# Obrigatório se AUTH_ENABLED=true — segredo para assinar JWT (use valor longo e aleatório em produção).
AUTH_JWT_SECRET=ABC123
# Tempo de vida do token em minutos (padrão 480 = 8h).
# AUTH_JWT_EXPIRE_MINUTES=480
# AUTH_JWT_ALGORITHM=HS256
# Nome do cookie HTTP-only com o JWT (padrão pdf_tools_auth).
# AUTH_COOKIE_NAME=pdf_tools_auth
# Em produção com HTTPS, defina true.
# AUTH_COOKIE_SECURE=false
# lax | strict | none
# AUTH_COOKIE_SAMESITE=lax

# --- LDAP (quando AUTH_PROVIDER=ldap) ---
LDAP_HOST=172.18.0.80
LDAP_PORT=389
LDAP_DOMAIN="@spotsul.local"

# Opcional: ver backend/.env.example (UPN / login curto).
# LDAP_DOMAIN=
# Conta de serviço para pesquisar o DN do usuário (opcional; se vazio, tenta bind anônimo).
# LDAP_BIND_DN=
# LDAP_BIND_PASSWORD=
# Base de busca de usuários.
LDAP_USER_BASE_DN=DC=spotsul,DC=local
# Filtro com placeholder %(username)s — o valor é escapado para LDAP.
# Exemplo AD: (sAMAccountName=%(username)s)
# Exemplo OpenLDAP: (uid=%(username)s)
# LDAP_USER_FILTER=
# LDAP_START_TLS=false
# true para LDAPS (porta típica 636).
# LDAP_USE_SSL=false
