# Origens CORS permitidas (separadas por vírgula). Se omitida, usa o padrão de desenvolvimento
# (localhost/127.0.0.1 nas portas 5173 e 4173).
# CORS_ORIGINS=https://app.exemplo.com,http://localhost:5173

# Servir o build do frontend pela API (caminho absoluto para frontend/dist)
# PDF_TOOLS_STATIC=

# Sobrescreve o diretório de uploads temporários. Se omitido: backend/data/uploads ao rodar a partir
# do repositório; se instalado só como wheel, <temp>/pdf_tools_uploads.
# PDF_TOOLS_UPLOAD_DIR=

# --- Autenticação (opcional) ---
# AUTH_ENABLED=false
# Provedor ativo quando AUTH_ENABLED=true. Hoje: apenas ldap.
# AUTH_PROVIDER=ldap
# Obrigatório se AUTH_ENABLED=true — segredo para assinar JWT (use valor longo e aleatório em produção).
# AUTH_JWT_SECRET=
# Tempo de vida do token em minutos (padrão 480 = 8h).
# AUTH_JWT_EXPIRE_MINUTES=480
# AUTH_JWT_ALGORITHM=HS256
# Nome do cookie HTTP-only com o JWT (padrão pdf_tools_auth).
# AUTH_COOKIE_NAME=pdf_tools_auth
# Em produção com HTTPS, defina true.
# AUTH_COOKIE_SECURE=false
# lax | strict | none
# AUTH_COOKIE_SAMESITE=lax

# --- LDAP (quando AUTH_PROVIDER=ldap) ---
# search = busca o DN do usuário e depois faz bind (precisa de LDAP_BIND_DN em muitos AD).
# upn = bind direto como login@dominio (sem busca; exige LDAP_DOMAIN).
# LDAP_AUTH_MODE=search
# Host ou IP (sem ldap://). Alias opcional: LDAP_HOSTNAME.
# LDAP_HOST=172.18.0.80
# LDAP_HOSTNAME=ldap.spotsul.local
# Porta. Se omitida: 389 sem SSL, 636 com SSL.
# LDAP_PORT=389
# Opcional (ex.: AD + UPN). Aceita "dominio.corp" ou "@dominio.corp".
# LDAP_DOMAIN=@spotsul.local
# Conta de serviço (opcional; se vazio, tenta bind anônimo).
# LDAP_BIND_DN=
# LDAP_BIND_PASSWORD=
# Base de busca. Alias opcional: LDAP_BASE_DN.
# LDAP_USER_BASE_DN=DC=spotsul,DC=local
# LDAP_BASE_DN=DC=spotsul,DC=local
# Filtro com placeholders (valores escapados para LDAP):
#   %(username)s — login curto (ex.: sAMAccountName no AD)
#   %(upn)s / %(user_principal_name)s — UPN; usa LDAP_DOMAIN se o login não tiver @
# Exemplo (Active Directory):
# LDAP_USER_FILTER=(&(objectCategory=*)(sAMAccountName=%(username)s))
# LDAP_USER_FILTER=
# STARTTLS / LDAPS — aliases opcionais: LDAP_TLS e LDAP_SSL.
# LDAP_START_TLS=false
# LDAP_TLS=false
# LDAP_USE_SSL=false
# LDAP_SSL=false
# Timeout de conexão/operação (segundos).
# LDAP_TIMEOUT=5
# Seguir referrals do servidor (ldap3). LDAP_OPT_REFERRALS=0 desliga.
# LDAP_OPT_REFERRALS=0
