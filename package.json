{
  "name": "pdf-tools",
  "private": true,
  "version": "1.3.0",
  "license": "GPL-3.0",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd backend && .venv/bin/uvicorn pdf_tools.main:app --reload --host 127.0.0.1 --port 8000",
    "dev:web": "npm run dev --prefix frontend",
    "build:web": "npm run build --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
